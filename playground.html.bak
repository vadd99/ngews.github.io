<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Platform Video - NGews</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        /* CSS RESET & VARIABLES */
        :root {
            --bg-base: #0a0712;
            --bg-surface: #120d24;
            --bg-surface-hover: #1c1533;
            --accent: #b493ff;
            --accent-glow: rgba(180, 147, 255, 0.3);
            --text-main: #f3f1f6;
            --text-muted: #9e97b2;
            --border-color: #231b3d;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Plus Jakarta Sans', sans-serif; -webkit-tap-highlight-color: transparent; }
        body { background-color: var(--bg-base); color: var(--text-main); overflow-x: hidden; }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: var(--bg-base); }
        ::-webkit-scrollbar-thumb { background: var(--border-color); border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--accent); }

        /* HEADER */
        header {
            position: fixed; top: 0; left: 0; right: 0; height: 70px;
            background-color: rgba(10, 7, 18, 0.85); backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border-color); display: flex; align-items: center;
            justify-content: space-between; padding: 0 24px; z-index: 100;
        }

        .header-left { display: flex; align-items: center; gap: 16px; }
        .menu-toggle {
            background: none; border: none; color: var(--text-main); cursor: pointer;
            display: flex; align-items: center; justify-content: center; padding: 8px; border-radius: 50%; transition: var(--transition);
        }
        .menu-toggle:hover { background-color: var(--bg-surface-hover); color: var(--accent); }
        
        .logo { display: flex; align-items: center; font-weight: 700; font-size: 1.5rem; letter-spacing: -0.5px; color: var(--text-main); text-decoration: none; }
        .logo span { color: var(--accent); text-shadow: 0 0 10px var(--accent-glow); }
        
        .header-right { display: flex; align-items: center; }

        /* EXPANDABLE SEARCH */
        .expandable-search { position: relative; display: flex; align-items: center; justify-content: flex-end; height: 44px; }
        .search-input-expanding {
            position: absolute; right: 0; width: 0; height: 100%; opacity: 0; padding: 0;
            border: 1px solid transparent; border-radius: 50px; background-color: var(--bg-surface);
            color: var(--text-main); font-size: 0.95rem; transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease, padding 0.4s ease; outline: none;
        }
        .expandable-search.active .search-input-expanding { width: 320px; opacity: 1; padding: 10px 45px 10px 20px; border-color: var(--accent); box-shadow: 0 0 15px var(--accent-glow); }
        .search-icon-btn { background: none; border: none; color: var(--accent); cursor: pointer; width: 44px; height: 44px; border-radius: 50%; display: flex; align-items: center; justify-content: center; z-index: 10; transition: var(--transition); }
        .search-icon-btn:hover { background-color: rgba(180, 147, 255, 0.15); }

        /* WATCH PAGE LAYOUT */
        .watch-container {
            display: flex; flex-direction: column; padding: 100px 24px 40px;
            max-width: 1200px; margin: 0 auto; min-height: 100vh;
        }

        /* HEADER INFO (Judul & Breadcrumb) */
        .video-header-info { margin-bottom: 24px; }
        .breadcrumb { font-size: 0.85rem; color: var(--text-muted); margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
        .breadcrumb a { color: var(--text-muted); text-decoration: none; transition: var(--transition); }
        .breadcrumb a:hover { color: var(--accent); }
        .video-title { font-size: 1.8rem; font-weight: 700; line-height: 1.3; color: var(--text-main); letter-spacing: -0.5px; }

        /* PLAYER */
        .player-wrapper {
            width: 100%; background-color: #000; border-radius: 16px; overflow: hidden; position: relative;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5); aspect-ratio: 16 / 9; border: 1px solid var(--border-color);
        }
        
        /* Dukungan khusus Fullscreen API */
        .player-wrapper:fullscreen {
            border-radius: 0;
            border: none;
            aspect-ratio: auto;
            width: 100vw;
            height: 100vh;
        }

        .big-play-btn {
            position: relative; z-index: 2; width: 80px; height: 80px; border-radius: 50%;
            background-color: var(--accent); border: none; cursor: pointer; display: flex; align-items: center; justify-content: center;
            color: #0a0712; box-shadow: 0 0 30px var(--accent-glow); transition: var(--transition);
        }
        .big-play-btn:hover { transform: scale(1.1); background-color: var(--text-main); }

        .player-controls {
            position: absolute; bottom: 0; left: 0; right: 0; padding: 24px 20px 16px;
            background: linear-gradient(to top, rgba(0,0,0,0.9), transparent); z-index: 3; display: flex; flex-direction: column; gap: 12px;
            opacity: 0; transform: translateY(10px); transition: var(--transition);
        }
        .player-wrapper:hover .player-controls, .player-wrapper.playing .player-controls { opacity: 1; transform: translateY(0); }

        /* Tampilkan kontrol selalu di perangkat mobile saat disentuh */
        .player-wrapper:active .player-controls { opacity: 1; transform: translateY(0); }

        .timeline-container { width: 100%; height: 4px; background: rgba(255,255,255,0.2); border-radius: 2px; cursor: pointer; position: relative; }
        .timeline-progress { position: absolute; top: 0; left: 0; height: 100%; background-color: var(--accent); border-radius: 2px; width: 0%; box-shadow: 0 0 10px var(--accent-glow); }
        .controls-row { display: flex; justify-content: space-between; align-items: center; }
        .controls-left, .controls-right { display: flex; align-items: center; gap: 16px; color: var(--text-main); }
        .control-btn { background: none; border: none; color: var(--text-main); cursor: pointer; display: flex; align-items: center; transition: var(--transition); }
        .control-btn:hover { color: var(--accent); }
        .time-display { font-size: 0.85rem; font-weight: 500; }

        /* Elemen Umpan Balik Ketuk Dua Kali */
        .seek-feedback-overlay {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
            background: rgba(10, 7, 18, 0.75); border: 1px solid var(--border-color); color: var(--accent);
            padding: 12px 24px; border-radius: 30px; font-weight: 700; font-size: 1.1rem;
            letter-spacing: 0.5px; z-index: 8; pointer-events: none; opacity: 0;
            transition: opacity 0.2s ease; box-shadow: 0 0 20px rgba(180, 147, 255, 0.2);
        }
        .seek-feedback-overlay.active { opacity: 1; }

        /* CREATOR PROFILE SECTION */
        .creator-section {
            display: flex; align-items: center; justify-content: space-between;
            padding: 18px 0; border-bottom: 1px solid var(--border-color);
            margin-top: 16px; gap: 16px; flex-wrap: wrap;
        }
        .creator-info { display: flex; align-items: center; gap: 14px; }
        .creator-avatar-container { position: relative; }
        .creator-avatar {
            width: 46px; height: 46px; border-radius: 50%; object-fit: cover;
            border: 2px solid var(--accent); box-shadow: 0 0 10px rgba(180, 147, 255, 0.2);
        }
        .creator-status {
            position: absolute; bottom: 2px; right: 2px; width: 10px; height: 10px;
            border-radius: 50%; background-color: #10b981; border: 2px solid var(--bg-base);
        }
        .creator-text { display: flex; flex-direction: column; }
        .creator-name { font-weight: 600; font-size: 1rem; color: var(--text-main); display: flex; align-items: center; gap: 6px; }
        .creator-verified { color: var(--accent); display: inline-flex; }
        .creator-subs { font-size: 0.8rem; color: var(--text-muted); }
        
        .creator-actions { display: flex; gap: 12px; }
        .btn-follow {
            background-color: rgba(180, 147, 255, 0.1); border: 1px solid var(--accent);
            color: var(--accent); font-weight: 600; font-size: 0.85rem; padding: 8px 18px;
            border-radius: 8px; cursor: pointer; transition: var(--transition);
        }
        .btn-follow:hover { background-color: var(--accent); color: #0a0712; box-shadow: 0 0 15px var(--accent-glow); }

        /* ACTION ROW: DOWNLOAD & METADATA */
        .video-action-row {
            display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap;
            gap: 20px; padding: 18px 0; border-bottom: 1px solid var(--border-color); margin-bottom: 30px;
        }
        
        /* TECHNICAL METADATA */
        .technical-meta { display: flex; gap: 24px; flex-wrap: wrap; }
        .meta-item { display: flex; align-items: center; gap: 8px; color: var(--text-muted); font-size: 0.9rem; font-weight: 500; }
        .meta-item svg { color: var(--accent); }

        /* DOWNLOAD BUTTON */
        .btn-download-container { display: flex; gap: 12px; }
        .btn-download {
            background-color: var(--accent); color: #0a0712; border: none; padding: 12px 28px;
            border-radius: 8px; font-weight: 700; font-size: 0.95rem; cursor: pointer; display: inline-flex; align-items: center; gap: 10px;
            transition: var(--transition); box-shadow: 0 4px 15px var(--accent-glow);
        }
        .btn-download:hover { transform: translateY(-2px); background-color: var(--text-main); box-shadow: 0 6px 20px rgba(255, 255, 255, 0.2); }
        
        .btn-outline {
            background-color: transparent; border: 1px solid var(--border-color); color: var(--text-main);
            padding: 12px 16px; border-radius: 8px; cursor: pointer; display: inline-flex; align-items: center; gap: 8px; transition: var(--transition);
        }
        .btn-outline:hover { border-color: var(--accent); color: var(--accent); background-color: var(--bg-surface-hover); }

        /* COMPACT DISCUSSION / COMMENTS SECTION */
        .comments-section {
            margin-bottom: 48px; background-color: rgba(18, 13, 36, 0.4);
            border: 1px solid var(--border-color); border-radius: 16px; padding: 20px;
        }
        .comments-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
        .comments-title { font-size: 1.1rem; font-weight: 700; color: var(--text-main); display: flex; align-items: center; gap: 8px; }
        .comments-count-badge { background-color: var(--bg-surface-hover); color: var(--accent); padding: 2px 10px; border-radius: 12px; font-size: 0.8rem; font-weight: 600; border: 1px solid var(--border-color); }
        
        /* New Comment Input */
        .comment-input-area { display: flex; gap: 12px; margin-bottom: 24px; align-items: flex-start; }
        .user-avatar-current { width: 36px; height: 36px; border-radius: 50%; object-fit: cover; border: 1.5px solid var(--border-color); }
        .comment-form { flex-grow: 1; display: flex; flex-direction: column; gap: 10px; }
        .comment-textarea-wrapper { position: relative; border-radius: 10px; background-color: var(--bg-surface); border: 1px solid var(--border-color); transition: var(--transition); }
        .comment-textarea-wrapper:focus-within { border-color: var(--accent); box-shadow: 0 0 10px rgba(180, 147, 255, 0.15); }
        .comment-textarea {
            width: 100%; min-height: 44px; max-height: 120px; background: transparent; border: none;
            color: var(--text-main); padding: 12px 16px; font-size: 0.9rem; resize: vertical; outline: none;
        }
        .comment-textarea::placeholder { color: var(--text-muted); }
        
        .comment-actions-bar { display: flex; justify-content: flex-end; gap: 10px; height: 0; overflow: hidden; opacity: 0; transition: var(--transition); }
        .comment-form.active .comment-actions-bar { height: 36px; opacity: 1; }
        
        .btn-comment-cancel { background: none; border: none; color: var(--text-muted); font-size: 0.85rem; font-weight: 600; cursor: pointer; padding: 0 12px; border-radius: 6px; transition: var(--transition); }
        .btn-comment-cancel:hover { color: var(--text-main); background-color: var(--bg-surface-hover); }
        .btn-comment-submit { background-color: var(--accent); color: #0a0712; border: none; font-size: 0.85rem; font-weight: 700; cursor: pointer; padding: 0 16px; border-radius: 6px; transition: var(--transition); }
        .btn-comment-submit:hover { transform: translateY(-1px); box-shadow: 0 4px 10px var(--accent-glow); }

        /* Comment List (Minimalist Layout) */
        .comments-list { display: flex; flex-direction: column; gap: 18px; max-height: 380px; overflow-y: auto; padding-right: 6px; }
        .comment-item { display: flex; gap: 12px; align-items: flex-start; padding-bottom: 14px; border-bottom: 1px solid rgba(35, 27, 61, 0.4); }
        .comment-item:last-child { border-bottom: none; padding-bottom: 0; }
        
        .comment-avatar { width: 34px; height: 34px; border-radius: 50%; object-fit: cover; }
        .comment-content { display: flex; flex-direction: column; gap: 4px; flex-grow: 1; }
        .comment-user-meta { display: flex; align-items: center; gap: 8px; font-size: 0.85rem; }
        .comment-username { font-weight: 600; color: var(--text-main); }
        .comment-badge { font-size: 0.7rem; background-color: rgba(180, 147, 255, 0.15); color: var(--accent); padding: 1px 6px; border-radius: 4px; font-weight: 500; }
        .comment-time { color: var(--text-muted); font-size: 0.75rem; }
        .comment-text { font-size: 0.9rem; color: #dfdaec; line-height: 1.45; word-break: break-word; }
        
        /* Minimalist Comment Actions */
        .comment-item-actions { display: flex; align-items: center; gap: 14px; margin-top: 4px; }
        .comment-action-btn { background: none; border: none; color: var(--text-muted); font-size: 0.75rem; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: 4px; transition: var(--transition); }
        .comment-action-btn:hover { color: var(--accent); }
        .comment-action-btn svg { width: 14px; height: 14px; }

        /* RELATED VIDEOS GRID - Optimized to 4 Columns */
        .related-title { font-size: 1.4rem; font-weight: 700; margin-bottom: 24px; display: flex; align-items: center; gap: 12px; }
        .related-title::before { content: ''; display: inline-block; width: 4px; height: 24px; background-color: var(--accent); border-radius: 2px; }

        #relatedVideosContainer { 
            display: grid; 
            grid-template-columns: repeat(4, 1fr); 
            gap: 20px; 
            margin-bottom: 24px; 
        }
        
        /* Fade-in Animation for Loaded Cards */
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(15px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .related-card {
            background-color: var(--bg-surface); border-radius: 12px; overflow: hidden;
            border: 1px solid var(--border-color); transition: var(--transition); cursor: pointer; display: flex; flex-direction: column;
            animation: fadeInUp 0.5s ease forwards;
        }
        .related-card:hover { transform: translateY(-4px); border-color: rgba(180, 147, 255, 0.4); box-shadow: 0 10px 25px rgba(10, 7, 18, 0.5), 0 0 15px rgba(180, 147, 255, 0.05); }
        
        .related-thumb-container { position: relative; width: 100%; padding-top: 56.25%; background-color: #1a1530; overflow: hidden; }
        .related-thumb { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; transition: var(--transition); }
        .related-card:hover .related-thumb { transform: scale(1.05); }
        .related-duration {
            position: absolute; bottom: 8px; right: 8px; background: rgba(10, 7, 18, 0.85); color: var(--text-main);
            padding: 2px 6px; border-radius: 4px; font-size: 0.7rem; font-weight: 600; backdrop-filter: blur(4px);
        }
        
        .related-info { padding: 14px; display: flex; flex-direction: column; }
        .related-video-title {
            font-size: 0.95rem; font-weight: 600; line-height: 1.35; color: var(--text-main); margin-bottom: 6px;
            display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; transition: var(--transition);
        }
        .related-card:hover .related-video-title { color: var(--accent); }
        .related-meta { font-size: 0.8rem; color: var(--text-muted); display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
        .related-meta span { display: flex; align-items: center; gap: 4px; }

        /* LOAD MORE BUTTON CONTAINER (NEW Addition) */
        .load-more-container {
            display: flex;
            justify-content: center;
            margin-top: 10px;
            margin-bottom: 60px;
        }
        
        .btn-load-more {
            background-color: transparent;
            border: 1px solid var(--border-color);
            color: var(--accent);
            padding: 14px 36px;
            border-radius: 50px;
            font-weight: 700;
            font-size: 0.95rem;
            cursor: pointer;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            box-shadow: 0 4px 15px rgba(180, 147, 255, 0.05);
        }
        
        .btn-load-more:hover {
            border-color: var(--accent);
            color: var(--text-main);
            background-color: rgba(180, 147, 255, 0.1);
            box-shadow: 0 0 20px var(--accent-glow);
            transform: translateY(-2px);
        }

        .btn-load-more:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
        }

        /* Animation Keyframe for Loading Spinner */
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        /* FOOTER */
        footer {
            border-top: 1px solid var(--border-color); padding: 40px 0; margin-top: auto;
            display: flex; flex-direction: column; align-items: center; gap: 20px; text-align: center;
        }
        .footer-links { display: flex; gap: 24px; flex-wrap: wrap; justify-content: center; }
        .footer-links a { color: var(--text-muted); text-decoration: none; font-size: 0.85rem; transition: var(--transition); font-weight: 500; }
        .footer-links a:hover { color: var(--accent); }
        .copyright { font-size: 0.8rem; color: var(--text-muted); }

        /* HIDDEN SIDEBAR NAVIGATION (Drawer) */
        .nav-drawer { position: fixed; top: 70px; left: -300px; bottom: 0; width: 260px; background-color: var(--bg-surface); border-right: 1px solid var(--border-color); z-index: 90; transition: var(--transition); padding: 24px 16px; overflow-y: auto; }
        .nav-drawer.active { left: 0; box-shadow: 10px 0 30px rgba(0,0,0,0.5); }
        .drawer-overlay { position: fixed; top: 70px; left: 0; right: 0; bottom: 0; background: rgba(10,7,18,0.7); z-index: 89; backdrop-filter: blur(4px); display: none; opacity: 0; transition: opacity 0.3s ease; }
        .drawer-overlay.active { display: block; opacity: 1; }
        
        .sidebar-menu { list-style: none; display: flex; flex-direction: column; gap: 8px; margin-bottom: 32px; }
        .sidebar-title { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1.5px; color: var(--text-muted); margin-left: 12px; margin-bottom: 12px; font-weight: 700; }
        .sidebar-item a { display: flex; align-items: center; gap: 16px; padding: 12px 16px; color: var(--text-muted); text-decoration: none; border-radius: 12px; font-size: 0.95rem; font-weight: 500; transition: var(--transition); }
        .sidebar-item a:hover, .sidebar-item.active a { color: var(--text-main); background-color: var(--bg-surface-hover); }

        /* RESPONSIVE LAYOUT */
        @media (max-width: 1024px) {
            #relatedVideosContainer { grid-template-columns: repeat(3, 1fr); gap: 18px; }
        }
        @media (max-width: 768px) {
            .video-title { font-size: 1.4rem; }
            .player-wrapper { border-radius: 0; margin: 0 -24px; width: calc(100% + 48px); border-left: none; border-right: none; }
            .watch-container { padding: 94px 24px 16px; }
            header { padding: 0 16px; }
            .expandable-search.active .search-input-expanding { width: 200px; }
            
            /* Responsive 2-Columns on Mobile for Compact View */
            #relatedVideosContainer { grid-template-columns: repeat(2, 1fr); gap: 14px; }
            .related-info { padding: 10px; }
            .related-video-title { font-size: 0.85rem; margin-bottom: 4px; }
            .related-meta { font-size: 0.75rem; gap: 4px; }

            .video-action-row { flex-direction: column; align-items: stretch; gap: 24px; }
            .btn-download-container { flex-direction: column; }
            .btn-download { width: 100%; justify-content: center; }
            .btn-outline { width: 100%; justify-content: center; }
            .creator-section { flex-direction: column; align-items: flex-start; gap: 14px; }
            .creator-actions { width: 100%; }
            .btn-follow { width: 100%; text-align: center; }
            .comments-section { padding: 16px; }
        }
    </style>
</head>
<body>

    <!-- HEADER -->
    <header>
        <div class="header-left">
            <button class="menu-toggle" id="menuToggleBtn" aria-label="Toggle Navigation">
                <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h16"></path></svg>
            </button>
            <a href="index.html" class="logo">NG<span>ews</span></a>
        </div>

        <div class="header-right">
            <!-- Expandable Search -->
            <div class="expandable-search" id="expandableSearch">
                <input type="text" class="search-input-expanding" id="searchInput" placeholder="Cari aset video...">
                <button class="search-icon-btn" id="searchToggleBtn" aria-label="Cari">
                    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </button>
            </div>
        </div>
    </header>

    <!-- HIDDEN NAVIGATION DRAWER -->
    <div class="drawer-overlay" id="drawerOverlay"></div>
    <aside class="nav-drawer" id="navDrawer">
        <p class="sidebar-title">Menu Utama</p>
        <ul class="sidebar-menu">
            <li class="sidebar-item">
                <a href="index.html">
                    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                    Beranda
                </a>
            </li>
            <li class="sidebar-item">
                <a href="#">
                    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.158.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                    Koleksi Saya
                </a>
            </li>
        </ul>
        <p class="sidebar-title">Kategori</p>
        <ul class="sidebar-menu">
            <li class="sidebar-item"><a href="#">🎥 Sinematik</a></li>
            <li class="sidebar-item"><a href="#">💻 Teknologi</a></li>
            <li class="sidebar-item"><a href="#">🎨 Estetika</a></li>
        </ul>
    </aside>

    <!-- WATCH LAYOUT -->
    <div class="watch-container">
        
        <!-- HEADER INFO -->
        <div class="video-header-info">
            <div class="breadcrumb">
                <a href="index.html">Beranda</a> 
                <span>/</span> 
                <a href="#" id="breadcrumbCategory">Kategori</a> 
                <span>/</span> 
                <span>Memuat...</span>
            </div>
            <h1 class="video-title">Memuat Judul Video...</h1>
        </div>

        <!-- VIDEO PLAYER -->
        <div class="player-wrapper" id="videoPlayerWrapper">
            <!-- Wadah dinamis untuk video asli (.mp4) atau embed (iframe GDrive) -->
            <div id="playerContainer" style="width: 100%; height: 100%;"></div>
            
            <!-- Elemen Teks Umpan Balik Kustom Detik (Double Tap Feedback) -->
            <div class="seek-feedback-overlay" id="seekFeedback">5s ⏩</div>

            <!-- Tombol Play Tengah Besar -->
            <div style="position: absolute; top:50%; left:50%; transform:translate(-50%, -50%); z-index:9; transition: var(--transition);" id="centerPlayBtnContainer">
                <button class="big-play-btn" id="mainPlayBtn">
                    <svg width="32" height="32" fill="currentColor" viewBox="0 0 24 24" id="playIconSVG"><path d="M8 5v14l11-7z"></path></svg>
                </button>
            </div>

            <!-- Kontrol Player Bawah Custom -->
            <div class="player-controls">
                <div class="timeline-container" id="timelineContainer">
                    <div class="timeline-progress" id="timelineProgress"></div>
                </div>
                <div class="controls-row">
                    <div class="controls-left">
                        <button class="control-btn" id="bottomPlayBtn">
                            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24" id="bottomPlayIcon"><path d="M8 5v14l11-7z"></path></svg>
                        </button>
                        <button class="control-btn" aria-label="Volume">
                            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15.536 8.464a5 5 0 010 7.072M17.95 6.05a8 8 0 010 11.9M11 5L6 9H2v6h4l5 4V5z"></path></svg>
                        </button>
                        <span class="time-display" id="timeDisplay">0:00 / 0:00</span>
                    </div>
                    <div class="controls-right">
                        <span style="font-size: 0.8rem; font-weight: 600; margin-right: 8px;">1080p</span>
                        <button class="control-btn" aria-label="Fullscreen" id="customFullscreenBtn">
                            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"></path></svg>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- CREATOR PROFILE SECTION -->
        <div class="creator-section">
            <div class="creator-info">
                <div class="creator-avatar-container">
                    <img class="creator-avatar" src="" alt="Avatar Saluran" id="creatorAvatar">
                    <div class="creator-status"></div>
                </div>
                <div class="creator-text">
                    <span class="creator-name" id="creatorName">
                        Nama Saluran
                    </span>
                    <span class="creator-subs" id="videoViewsCount">0x ditonton • Memuat...</span>
                </div>
            </div>
            <div class="creator-actions">
                <button class="btn-follow" id="followBtn">Ikuti Studio</button>
            </div>
        </div>

        <!-- ACTION ROW: DOWNLOAD & METADATA -->
        <div class="video-action-row">
            <div class="technical-meta">
                <div class="meta-item">
                    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                    <span>1080p HD</span>
                </div>
                <div class="meta-item">
                    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    <span>MP4 Mentah / Embed</span>
                </div>
                <div class="meta-item">
                    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                    <span>Bebas Lisensi (Blog)</span>
                </div>
            </div>

            <div class="btn-download-container">
                <button class="btn-outline">
                    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"></path></svg>
                    Simpan ke Koleksi
                </button>
                <button class="btn-download" id="downloadTargetBtn">
                    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                    Buka Link Video
                </button>
            </div>
        </div>

        <!-- COMPACT COMMENTS SECTION -->
        <section class="comments-section">
            <div class="comments-header">
                <h3 class="comments-title">
                    Diskusi
                    <span class="comments-count-badge" id="commentCount">3</span>
                </h3>
            </div>
            
            <div class="comment-input-area">
                <img class="user-avatar-current" src="https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&fit=crop&w=150&q=80" alt="Avatar Anda">
                <div class="comment-form" id="commentForm">
                    <div class="comment-textarea-wrapper">
                        <textarea class="comment-textarea" id="commentInput" placeholder="Tulis komentar publik Anda..." rows="1"></textarea>
                    </div>
                    <div class="comment-actions-bar">
                        <button class="btn-comment-cancel" id="commentCancelBtn" type="button">Batal</button>
                        <button class="btn-comment-submit" id="commentSubmitBtn" type="button">Kirim</button>
                    </div>
                </div>
            </div>

            <div class="comments-list" id="commentsList">
                <div class="comment-item">
                    <img class="comment-avatar" src="https://images.unsplash.com/photo-1570295999919-56ceb5ecca61?auto=format&fit=crop&w=150&q=80" alt="Avatar Pengguna 1">
                    <div class="comment-content">
                        <div class="comment-user-meta">
                            <span class="comment-username">Rian Pratama</span>
                            <span class="comment-badge">Kolektor</span>
                            <span class="comment-time">2 jam yang lalu</span>
                        </div>
                        <p class="comment-text">Kombinasi warna violet dan lampu ambient LED estetik banget! Izin tonton ya mas untuk inspirasi video projek kantor.</p>
                        <div class="comment-item-actions">
                            <button class="comment-action-btn">
                                <svg fill="currentColor" viewBox="0 0 24 24"><path d="M1 21h4V9H1v12zm22-11c0-1.1-.9-2-2-2h-6.31l.95-4.57.03-.32c0-.41-.17-.79-.44-1.06L14.17 1 7.59 7.59C7.22 7.95 7 8.45 7 9v10c0 1.1.9 2 2 2h9c.83 0 1.54-.5 1.84-1.22l3.02-7.05c.09-.23.14-.47.14-.73v-2z"></path></svg>
                                <span>14</span>
                            </button>
                            <button class="comment-action-btn">Balas</button>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- RELATED VIDEOS GRID -->
        <h3 class="related-title">Video Serupa untuk Anda</h3>
        <div id="relatedVideosContainer"></div>

        <!-- LOAD MORE BUTTON -->
        <div class="load-more-container">
            <button class="btn-load-more" id="loadMoreBtn">Lihat Lebih Banyak</button>
        </div>

        <!-- FOOTER -->
        <footer>
            <div class="footer-links">
                <a href="#">Tentang Kami</a>
                <a href="#">Lisensi Konten</a>
                <a href="#">Syarat Layanan</a>
                <a href="#">Kebijakan Privasi</a>
                <a href="#">Bantuan & Dukungan</a>
            </div>
            <div class="copyright">&copy; 2026 NGews. Platform Aset Video Minimalis.</div>
        </footer>

    </div>

    <script>
        // 1. Dapatkan ID Video dari URL parameter (?id=X)
        const urlParams = new URLSearchParams(window.location.search);
        const videoId = parseInt(urlParams.get('id'));

        // DOM Elements Konten Halaman Video
        const videoTitleEl = document.querySelector('.video-title');
        const creatorNameEl = document.getElementById('creatorName');
        const creatorAvatarEl = document.getElementById('creatorAvatar');
        const videoViewsCountEl = document.getElementById('videoViewsCount');
        const breadcrumbCategory = document.getElementById('breadcrumbCategory');
        const breadcrumbCurrent = document.querySelector('.breadcrumb span:last-child');
        const downloadTargetBtn = document.getElementById('downloadTargetBtn');
        
        // DOM Elements untuk Player Utama & Kontrol Custom
        const playerContainer = document.getElementById('playerContainer');
        const videoPlayerWrapper = document.getElementById('videoPlayerWrapper');
        const mainPlayBtn = document.getElementById('mainPlayBtn');
        const centerPlayBtnContainer = document.getElementById('centerPlayBtnContainer');
        const bottomPlayBtn = document.getElementById('bottomPlayBtn');
        const bottomPlayIcon = document.getElementById('bottomPlayIcon');
        const timelineProgress = document.getElementById('timelineProgress');
        const timeDisplay = document.getElementById('timeDisplay');
        const timelineContainer = document.getElementById('timelineContainer');
        const customFullscreenBtn = document.getElementById('customFullscreenBtn');
        const seekFeedback = document.getElementById('seekFeedback');

        let mockVideos = [];
        const playSVG = `<path d="M8 5v14l11-7z"></path>`;
        const pauseSVG = `<path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"></path>`;

        // 2. Ambil data dari postingan.json secara dinamis
        async function muatHalamanVideo() {
            try {
                const response = await fetch('./postingan.json');
                mockVideos = await response.json();
                
                // Cari video yang ID-nya cocok dengan parameter URL
                const videoData = mockVideos.find(v => v.id === videoId);
                
                if (videoData) {
                    // Update Detail Informasi Halaman
                    videoTitleEl.textContent = videoData.title;
                    breadcrumbCurrent.textContent = videoData.title;
                    breadcrumbCategory.textContent = videoData.category || "Berita";
                    creatorAvatarEl.src = videoData.avatar;
                    videoViewsCountEl.textContent = `${videoData.views || '0'} ditonton • ${videoData.time || 'Baru saja'}`;
                    creatorNameEl.innerHTML = `${videoData.channel} <span class="creator-verified"><svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"></path></svg></span>`;
                    
                    // Set aksi tombol download mengarah langsung ke URL video
                    downloadTargetBtn.onclick = () => window.open(videoData.videoUrl, '_blank');

                    // Bersihkan wadah player utama sebelum memuat elemen baru
                    playerContainer.innerHTML = '';

                    // PERIKSA JENIS MEDIA (GOOGLE DRIVE EMBED ATAU MEDIA MENTAH MP4)
                    if (videoData.videoUrl.includes('drive.google.com') || videoData.videoUrl.includes('dood')) {
                        // Membuat elemen iframe untuk Google Drive atau Doodstream
                        const iframe = document.createElement('iframe');
                        iframe.src = videoData.videoUrl;
                        iframe.style.width = '100%';
                        iframe.style.height = '100%';
                        iframe.style.border = 'none';
                        iframe.setAttribute('allow', 'autoplay');
                        iframe.setAttribute('allowfullscreen', 'true');
                        
                        playerContainer.appendChild(iframe);
                        
                        // Sembunyikan semua kontrol & tombol kustom
                        if (centerPlayBtnContainer) centerPlayBtnContainer.style.display = 'none';
                        const customControls = document.querySelector('.player-controls');
                        if (customControls) customControls.style.display = 'none';
                    } else {
                        // Membuat elemen video HTML5 asli untuk file .mp4
                        const video = document.createElement('video');
                        video.id = 'mainVideoPlayer';
                        video.src = videoData.videoUrl;
                        video.poster = videoData.thumbnail;
                        video.style.width = '100%';
                        video.style.height = '100%';
                        video.style.objectFit = 'contain'; /* Diubah ke contain agar video vertikal tidak crop dan kiri kanan gelap */
                        video.style.backgroundColor = '#000000';
                        video.style.display = 'block';
                        
                        playerContainer.appendChild(video);
                        
                        // Tampilkan kembali elemen UI kontrol kustom
                        if (centerPlayBtnContainer) {
                            centerPlayBtnContainer.style.display = 'block';
                            centerPlayBtnContainer.style.opacity = '1';
                        }
                        const customControls = document.querySelector('.player-controls');
                        if (customControls) customControls.style.display = 'flex';
                        
                        window.globalVideoPlayer = video;
                        inisialisasiKontrolVideo();
                    }
                } else {
                    videoTitleEl.textContent = "Video Tidak Ditemukan";
                }

                // Tampilkan rekomendasi video serupa
                const videoSerupa = mockVideos.filter(v => v.id !== videoId);
                renderVideos(videoSerupa);

            } catch (error) {
                console.error("Gagal memuat data video:", error);
            }
        }

        // 3. Logika Pengendali Pemutar Video Asli (Khusus File Mentah / MP4)
        function inisialisasiKontrolVideo() {
            const activePlayer = window.globalVideoPlayer;
            if (!activePlayer) return;

            function formatTime(seconds) {
                const m = Math.floor(seconds / 60);
                const s = Math.floor(seconds % 60);
                return `${m}:${s < 10 ? '0' : ''}${s}`;
            }

            // Fungsi tunggal untuk mengontrol Play / Pause secara bergantian
            function eksekusiTogglePlay() {
                if (activePlayer.paused) {
                    activePlayer.play().then(() => {
                        bottomPlayIcon.innerHTML = pauseSVG;
                        mainPlayBtn.innerHTML = pauseSVG;
                        centerPlayBtnContainer.style.opacity = '0';
                        setTimeout(() => { if(!activePlayer.paused) centerPlayBtnContainer.style.display = 'none'; }, 300);
                        videoPlayerWrapper.classList.add('playing');
                    }).catch(err => console.log("Playback diblokir otomatis oleh browser."));
                } else {
                    activePlayer.pause();
                    bottomPlayIcon.innerHTML = playSVG;
                    mainPlayBtn.innerHTML = playSVG;
                    centerPlayBtnContainer.style.display = 'block';
                    setTimeout(() => centerPlayBtnContainer.style.opacity = '1', 10);
                    videoPlayerWrapper.classList.remove('playing');
                }
            }

            // Daftarkan event klik pada seluruh tombol pemicu utama
            bottomPlayBtn.addEventListener('click', (e) => { e.stopPropagation(); eksekusiTogglePlay(); });
            mainPlayBtn.addEventListener('click', (e) => { e.stopPropagation(); eksekusiTogglePlay(); });
            
            // Klik tunggal di area playerContainer untuk Play/Pause (Menghindari gangguan double-click)
            let clickTimeout;
            playerContainer.addEventListener('click', (e) => {
                if (e.target.tagName === 'VIDEO') {
                    if (!clickTimeout) {
                        clickTimeout = setTimeout(() => {
                            clickTimeout = null;
                            eksekusiTogglePlay();
                        }, 250); // Delay menunggu konfirmasi apakah user mau double click
                    }
                }
            });

            // LOGIKA FITUR BARU: KETUK DUA KALI (DOUBLE CLICK / TAP) UNTUK SEEEK 5 DETIK
            playerContainer.addEventListener('dblclick', (e) => {
                clearTimeout(clickTimeout); // Batalkan aksi single-click pause
                clickTimeout = null;

                const rect = playerContainer.getBoundingClientRect();
                const clickX = e.clientX - rect.left; // Koordinat X posisi ketukan
                const lebarPlayer = rect.width;

                if (clickX < lebarPlayer / 2) {
                    // Sisi Kiri: Mundur 5 detik
                    activePlayer.currentTime = Math.max(activePlayer.currentTime - 5, 0);
                    tampilkanTeksFeedback('⏪ 5s Mundur');
                } else {
                    // Sisi Kanan: Maju 5 detik
                    activePlayer.currentTime = Math.min(activePlayer.currentTime + 5, activePlayer.duration);
                    tampilkanTeksFeedback('Maju 5s ⏩');
                }
            });

            function tampilkanTeksFeedback(teks) {
                seekFeedback.textContent = teks;
                seekFeedback.classList.add('active');
                setTimeout(() => {
                    seekFeedback.classList.remove('active');
                }, 600);
            }

            // LOGIKA FITUR BARU: CUSTOM LAYAR PENUH (FULLSCREEN)
            customFullscreenBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                if (!document.fullscreenElement) {
                    // Memasukkan seluruh wrapper termasuk UI custom lavender ke dalam fullscreen
                    videoPlayerWrapper.requestFullscreen().catch(err => {
                        console.error(`Gagal masuk Fullscreen: ${err.message}`);
                    });
                } else {
                    document.exitFullscreen();
                }
            });

            // Perbarui timeline progress bar dan teks durasi secara berkala saat video berjalan
            activePlayer.addEventListener('timeupdate', () => {
                const persentase = (activePlayer.currentTime / activePlayer.duration) * 100;
                timelineProgress.style.width = `${persentase}%`;
                timeDisplay.textContent = `${formatTime(activePlayer.currentTime)} / ${formatTime(activePlayer.duration || 0)}`;
            });

            // Klik di area garis timeline untuk mencari (seek) menit video
            timelineContainer.addEventListener('click', (e) => {
                const rect = timelineContainer.getBoundingClientRect();
                const clickX = e.clientX - rect.left;
                const progressWidth = rect.width;
                const posisiWaktu = (clickX / progressWidth) * activePlayer.duration;
                activePlayer.currentTime = posisiWaktu;
            });
        }

        // 4. Merender daftar rekomendasi video serupa ke grid bawah
        const relatedContainer = document.getElementById('relatedVideosContainer');
        function renderVideos(videosList) {
            relatedContainer.innerHTML = ''; 
            videosList.forEach(video => {
                const card = document.createElement('div');
                card.className = 'related-card';
                card.innerHTML = `
                    <div class="related-thumb-container">
                        <img src="${video.thumbnail}" alt="Thumbnail ${video.title}" class="related-thumb">
                        <div class="related-duration">${video.duration}</div>
                    </div>
                    <div class="related-info">
                        <h4 class="related-video-title" title="${video.title}">${video.title}</h4>
                        <div class="related-meta">
                            <span>🎥 ${video.category || 'Sinematik'}</span>
                            <span>•</span>
                            <span>${video.time}</span>
                        </div>
                    </div>
                `;
                card.addEventListener('click', () => {
                    window.location.href = `playground.html?id=${video.id}`;
                });
                relatedContainer.appendChild(card);
            });
        }

        // Panggil fungsi inisialisasi awal saat dokumen siap dibuka
        muatHalamanVideo();

        // LOGIKA PENUNJANG: INTERAKSI TOMBOL IKUTI STUDIO
        const followBtn = document.getElementById('followBtn');
        let isFollowing = false;
        followBtn.addEventListener('click', () => {
            isFollowing = !isFollowing;
            if(isFollowing) {
                followBtn.textContent = 'Mengikuti';
                followBtn.style.backgroundColor = 'var(--accent)';
                followBtn.style.color = '#0a0712';
            } else {
                followBtn.textContent = 'Ikuti Studio';
                followBtn.style.backgroundColor = 'rgba(180, 147, 255, 0.1)';
                followBtn.style.color = 'var(--accent)';
            }
        });

        // LOGIKA PENUNJANG: TAMBAH KOMENTAR DINAMIS
        const commentInput = document.getElementById('commentInput');
        const commentForm = document.getElementById('commentForm');
        const commentCancelBtn = document.getElementById('commentCancelBtn');
        const commentSubmitBtn = document.getElementById('commentSubmitBtn');
        const commentsList = document.getElementById('commentsList');
        const commentCountBadge = document.getElementById('commentCount');
        let countValue = 1;

        commentInput.addEventListener('focus', () => commentForm.classList.add('active'));
        commentCancelBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            commentInput.value = '';
            commentForm.classList.remove('active');
            commentInput.style.height = 'auto';
        });

        commentInput.addEventListener('input', function() {
            this.style.height = 'auto';
            this.style.height = (this.scrollHeight) + 'px';
        });

        commentSubmitBtn.addEventListener('click', () => {
            const teks = commentInput.value.trim();
            if (teks !== '') {
                countValue++;
                commentCountBadge.textContent = countValue;
                const item = document.createElement('div');
                item.className = 'comment-item';
                item.innerHTML = `
                    <img class="comment-avatar" src="https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&fit=crop&w=150&q=80">
                    <div class="comment-content">
                        <div class="comment-user-meta">
                            <span class="comment-username">Kamu (Kolektor)</span>
                            <span class="comment-badge">Baru</span>
                            <span class="comment-time">Baru saja</span>
                        </div>
                        <p class="comment-text">${teks.replace(/[&<>'"]/g, t => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[t]||t))}</p>
                        <div class="comment-item-actions">
                            <button class="comment-action-btn">👍 <span>0</span></button>
                            <button class="comment-action-btn">Balas</button>
                        </div>
                    </div>
                `;
                commentsList.insertBefore(item, commentsList.firstChild);
                commentInput.value = '';
                commentForm.classList.remove('active');
                commentInput.style.height = 'auto';
            }
        });

        // LOGIKA PENUNJANG: MENUTUP / MEMBUKA EXPANDABLE SEARCH & NAVIGATION DRAWER
        const searchToggleBtn = document.getElementById('searchToggleBtn');
        const expandableSearch = document.getElementById('expandableSearch');
        const expandingInput = document.getElementById('searchInput');
        const menuToggleBtn = document.getElementById('menuToggleBtn');
        const navDrawer = document.getElementById('navDrawer');
        const drawerOverlay = document.getElementById('drawerOverlay');

        searchToggleBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            if (!expandableSearch.classList.contains('active')) {
                expandableSearch.classList.add('active');
                expandingInput.focus();
            } else if (expandingInput.value === '') {
                expandableSearch.classList.remove('active');
            }
        });
        expandingInput.addEventListener('click', (e) => e.stopPropagation());
        document.addEventListener('click', () => {
            if (expandableSearch.classList.contains('active') && expandingInput.value === '') {
                expandableSearch.classList.remove('active');
            }
        });

        function toggleDrawer() {
            navDrawer.classList.toggle('active');
            drawerOverlay.classList.toggle('active');
        }
        menuToggleBtn.addEventListener('click', toggleDrawer);
        drawerOverlay.addEventListener('click', toggleDrawer);

        // LOGIKA PENUNJANG: SIMULASI LOADING BUTTON LIHAT LEBIH BANYAK
        const loadMoreBtn = document.getElementById('loadMoreBtn');
        loadMoreBtn.addEventListener('click', () => {
            loadMoreBtn.disabled = true;
            loadMoreBtn.innerHTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" style="animation: spin 0.8s linear infinite; margin-right: 8px;"><path d="M4 12a8 8 0 018-8" stroke="var(--accent)"></path></svg> Memuat...`;
            setTimeout(() => {
                loadMoreBtn.innerHTML = "Lihat Lebih Banyak";
                loadMoreBtn.disabled = false;
            }, 1000);
        });
    </script>
</body>
</html>
