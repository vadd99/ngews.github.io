<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Upload Postingan - NGews Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --bg-base: #0a0712; --bg-surface: #120d24; --accent: #b493ff;
            --text-main: #f3f1f6; --text-muted: #9e97b2; --border-color: #231b3d;
            --transition: all 0.3s ease;
        }
        * { box-sizing: border-box; font-family: 'Plus Jakarta Sans', sans-serif; }
        body { background-color: var(--bg-base); color: var(--text-main); padding-bottom: 60px; }
        
        .admin-container { max-width: 800px; margin: 40px auto; padding: 0 24px; }
        .form-card { background-color: var(--bg-surface); border: 1px solid var(--border-color); border-radius: 16px; padding: 32px; }
        
        .form-group { display: flex; flex-direction: column; gap: 8px; margin-bottom: 15px; }
        input, select { background-color: var(--bg-base); border: 1px solid var(--border-color); color: var(--text-main); padding: 12px; border-radius: 10px; }
        
        .tags-checklist { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 10px; background: var(--bg-base); padding: 15px; border-radius: 10px; border: 1px solid var(--border-color); }
        .tags-checklist label { cursor: pointer; font-size: 0.85rem; }
        
        .btn-submit { background-color: var(--accent); color: #0a0712; border: none; width: 100%; padding: 16px; border-radius: 10px; font-weight: 700; cursor: pointer; transition: var(--transition); }
        .btn-submit:disabled { background-color: #4a4365; cursor: not-allowed; }

        .alert-box { padding: 16px; border-radius: 10px; margin-bottom: 24px; font-weight: 600; display: none; text-align: center; }
        .alert-success { background-color: rgba(16, 185, 129, 0.2); border: 1px solid #10b981; color: #10b981; }
    </style>
</head>
<body>

    <div class="admin-container">
        <h1>Tambah Video Baru</h1>
        <div class="alert-box alert-success" id="successAlert">✅ Video berhasil dipublikasikan!</div>
        
        <div class="form-card">
            <form id="uploadForm">
                <div class="form-group">
                    <label>Judul Video</label>
                    <input type="text" id="inpTitle" required>
                </div>
                <div class="form-group">
                    <label>URL Video & Thumbnail</label>
                    <input type="url" id="inpVideoUrl" placeholder="Video URL" required>
                    <input type="url" id="inpThumbnail" placeholder="Thumbnail URL" required>
                </div>
                <div class="form-group">
                    <label>Kategori</label>
                    <input list="categoryList" id="inpCategory" placeholder="Pilih/Ketik kategori..." required>
                    <datalist id="categoryList"></datalist>
                </div>
                <div class="form-group">
                    <label>Negara</label>
                    <select id="inpCountry"></select>
                </div>
                <div class="form-group">
                    <label>Channel</label>
                    <select id="inpChannel"><option value="new">➕ Buat Channel Baru</option></select>
                    <input type="url" id="inpAvatar" placeholder="URL Avatar" style="display:none; margin-top:5px;">
                </div>
                <div class="form-group">
                    <label>Durasi (Contoh: 05:30)</label>
                    <input type="text" id="inpDuration" required>
                </div>
                <div class="form-group">
                    <label>Tags</label>
                    <div id="tagsContainer" class="tags-checklist"></div>
                    <input type="text" id="inpNewTags" placeholder="Tambah tag baru (pisahkan koma)...">
                </div>
                <button type="submit" class="btn-submit" id="btnSubmit">Publikasikan Video</button>
            </form>
        </div>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js";
        import { getFirestore, collection, getDocs, addDoc, serverTimestamp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore.js";

        // KONFIGURASI FIREBASE ANDA
        const firebaseConfig = {
            apiKey: "AIzaSyA8-TN3r2KNL-XEHZ5lF3-rkVyj2qQe9so",
            authDomain: "ngews-web.firebaseapp.com",
            projectId: "ngews-web",
            storageBucket: "ngews-web.firebasestorage.app",
            messagingSenderId: "1952425136",
            appId: "1:1952425136:web:3267816a6b05772d688775"
        };

        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);
        
        let channelMap = {};

        // 1. Load data lama agar Admin Panel cerdas
        async function loadAdminData() {
            const querySnapshot = await getDocs(collection(db, "videos"));
            const cats = new Set(), counts = new Set(), tags = new Set();
            querySnapshot.forEach(doc => {
                const d = doc.data();
                if(d.category) cats.add(d.category);
                if(d.country) counts.add(d.country);
                if(d.channel) { channelMap[d.channel] = d.avatar; addChannelOpt(d.channel); }
                if(d.tags) d.tags.forEach(t => tags.add(t));
            });
            
            cats.forEach(c => document.getElementById('categoryList').innerHTML += `<option value="${c}">`);
            counts.forEach(c => document.getElementById('inpCountry').innerHTML += `<option value="${c}">${c}</option>`);
            tags.forEach(t => document.getElementById('tagsContainer').innerHTML += `<label><input type="checkbox" value="${t}"> ${t}</label>`);
        }

        function addChannelOpt(name) {
            const sel = document.getElementById('inpChannel');
            if(![...sel.options].some(o => o.value === name)) sel.innerHTML += `<option value="${name}">${name}</option>`;
        }

        document.getElementById('inpChannel').addEventListener('change', (e) => {
            const av = document.getElementById('inpAvatar');
            av.style.display = (e.target.value === 'new' || e.target.value !== "") ? 'block' : 'none';
            av.value = channelMap[e.target.value] || "";
        });

        // 2. Kirim ke Firebase dengan Efek Loading
        document.getElementById('uploadForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('btnSubmit');
            btn.disabled = true;
            btn.textContent = "Sedang Mengunggah...";

            const finalTags = [...new Set([...[...document.querySelectorAll('#tagsContainer input:checked')].map(i => i.value), ...document.getElementById('inpNewTags').value.split(',').map(t => t.trim()).filter(t => t)])];

            try {
                await addDoc(collection(db, "videos"), {
                    title: document.getElementById('inpTitle').value,
                    videoUrl: document.getElementById('inpVideoUrl').value,
                    thumbnail: document.getElementById('inpThumbnail').value,
                    category: document.getElementById('inpCategory').value,
                    country: document.getElementById('inpCountry').value,
                    channel: document.getElementById('inpChannel').value,
                    avatar: document.getElementById('inpAvatar').value || "https://images.unsplash.com/photo-1535713875002-d1d0cf377fde",
                    duration: document.getElementById('inpDuration').value,
                    tags: finalTags,
                    views: 0, likes: 0, dislikes: 0, comments: [],
                    uploadDate: serverTimestamp()
                });
                
                document.getElementById('successAlert').style.display = 'block';
                document.getElementById('uploadForm').reset();
                setTimeout(() => document.getElementById('successAlert').style.display = 'none', 3000);
            } catch (err) { alert("Gagal: " + err.message); } 
            finally { btn.disabled = false; btn.textContent = "Publikasikan Video"; }
        });

        loadAdminData();
    </script>
</body>
</html>
